{
  "name": "prism-pitch-video",
  "version": "1.0.0",
  "description": "Prism 90-second pitch video — Remotion project",
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render src/index.ts PrismPitch out/prism-pitch.mp4",
    "render:quick": "remotion render src/index.ts PrismPitch out/prism-pitch.mp4 --concurrency=1",
    "still": "remotion still src/index.ts PrismPitch out/thumbnail.png"
  },
  "dependencies": {
    "@remotion/cli": "4.0.0",
    "remotion": "4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
