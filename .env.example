# Circle Developer-Controlled Wallets
CIRCLE_API_KEY=TEST_API_KEY:YOUR_KEY_HERE
CIRCLE_ENTITY_SECRET=YOUR_ENTITY_SECRET_HEX_HERE
CIRCLE_WALLET_SET_ID=YOUR_WALLET_SET_ID_HERE
CIRCLE_WALLET_TRADER_ID=YOUR_TRADER_WALLET_ID
CIRCLE_WALLET_TRADER_ADDRESS=0xYOUR_TRADER_ADDRESS
CIRCLE_WALLET_SENTINEL_ID=YOUR_SENTINEL_WALLET_ID
CIRCLE_WALLET_SENTINEL_ADDRESS=0xYOUR_SENTINEL_ADDRESS
CIRCLE_WALLET_ORACLE_ID=YOUR_ORACLE_WALLET_ID
CIRCLE_WALLET_ORACLE_ADDRESS=0xYOUR_ORACLE_ADDRESS

# Polymarket
POLY_BUILDER_CODE=0xYOUR_BUILDER_CODE_HERE
# HMAC secret used to derive builder codes from ERC-8004 agentIds.
# Must match the secret used by the polymarket-gateway service.
BUILDER_HMAC_SECRET=YOUR_BUILDER_HMAC_SECRET_HERE

# LLM providers
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Pinata IPFS
PINATA_API_KEY=YOUR_PINATA_API_KEY_HERE
PINATA_SECRET_KEY=YOUR_PINATA_SECRET_KEY_HERE
PINATA_JWT=YOUR_PINATA_JWT_HERE

# Neon Postgres (use pooled URL with -pooler suffix)
DATABASE_URL=NEON_POOLED_CONNECTION_STRING_HERE
DATABASE_URL_UNPOOLED=NEON_DIRECT_CONNECTION_STRING_HERE

# Arc testnet RPC
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_KEY_HERE
# Client-side mirror of ARC_RPC_URL — exposed to the dashboard via NEXT_PUBLIC_*.
# Operator should set this to the same value as ARC_RPC_URL on Railway.
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_KEY_HERE
# Arc Testnet USYC contract address. Optional. When unset, trader treasury
# module ships in `dry_run` mode and skips on-chain USYC calls.
USYC_ARC_TESTNET_ADDRESS=

# ERC-8004 agent IDs (populated after first registration on Arc)
TRADER_AGENT_ID=YOUR_TRADER_AGENT_ID_HERE
SENTINEL_AGENT_ID=YOUR_SENTINEL_AGENT_ID_HERE

# x402 nanopayment middleware (sentinel endpoint protection)
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base-sepolia
X402_PRICE_USDC=0.01
X402_RECIPIENT_ADDRESS=0xYOUR_RECIPIENT_ADDRESS_HERE
# x402 facilitator routing: `public` (default, x402.org on Base Sepolia) or `circle`
# (Circle facilitator on Arc Testnet). Both code paths coexist; operator flips to
# `circle` on Railway production only after a live receipt is captured.
X402_FACILITATOR_MODE=public
# Client-side mirror of X402_FACILITATOR_MODE — used by the BridgeWidget on /submit
# to determine the destination chain for USDC bridging (Base Sepolia vs Arc Testnet).
NEXT_PUBLIC_X402_FACILITATOR_MODE=public
# Sentinel's Arc Testnet receiving wallet; only consumed when X402_FACILITATOR_MODE=circle.
X402_ARC_RECIPIENT_ADDRESS=0xYOUR_ARC_RECIPIENT_ADDRESS_HERE
# Circle facilitator base URL for Arc Testnet settlement. As of 2026-05-15 the
# Circle facilitator endpoint for Arc Testnet is not publicly documented. When
# unset and mode=circle, the middleware falls back to mock settlement (no
# on-chain tx). Set this once Circle publishes the Arc Testnet facilitator endpoint.
# X402_CIRCLE_FACILITATOR_URL=https://circle-facilitator.example.com

# Polymarket live trading (optional — leave PRISM_TRADE_MODE=paper for Phase 0)
# POLY_FUNDER_SECRET=YOUR_POLY_FUNDER_SECRET_HERE
# POLY_CLOB_API_KEY=YOUR_POLY_CLOB_API_KEY_HERE
PRISM_TRADE_MODE=paper

# Next.js dashboard
NEXT_PUBLIC_SITE_URL=http://localhost:3200

# IPFS gateway for dashboard reads (Pinata gateway recommended for production)
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# --- Dashboard: Sentinel proxy ---
# Used by the /submit page API routes to proxy MCP + x402 calls to the sentinel.
# If SENTINEL_MCP_URL is set, it takes precedence; otherwise derived from SENTINEL_BASE_URL.
SENTINEL_BASE_URL=https://prism-sentinel-production.up.railway.app
# SENTINEL_MCP_URL=https://prism-sentinel-production.up.railway.app/mcp/

# --- Dashboard: Wallet Connect / Reown ---
# Used by the connect-wallet flow on /me and /submit pages.
# This project ID is public-safe (see Reown docs) and can be inlined.
# Operators with their own Reown project may override on Railway.
NEXT_PUBLIC_REOWN_PROJECT_ID=0169b238a503068cc520097200b51458

# --- Trader: idle-USDC yield routing ---
# `off` (default) preserves existing pipeline. `park` deposits residual USDC into
# USYC after each trace. `smart` parks only when sentinel verdict is REJECT/WARN.
TRADER_YIELD_MODE=off
