{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prism.fathin.dev/protocol/prism-report-v0.schema.json",
  "title": "Prism Report v0",
  "description": "Portable verifiable artifact for a single Prism adversarial validation report. JSON Schema Draft 2020-12. The v0 envelope splits sentinel identity (validator) from judgement (verdict) — the live API nests both under 'validation'. This schema is the canonical interchange format for third-party consumers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "trace",
    "action_intent",
    "validator",
    "verdict",
    "reasoning_metrics",
    "readiness",
    "warnings",
    "issue_ledger",
    "evidence_receipts",
    "capital_gate",
    "payment_receipts",
    "onchain_receipts",
    "content_hashes"
  ],
  "properties": {
    "schema_version": {
      "const": "prism.report.v0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "agent_id",
        "market_id",
        "market_question",
        "action",
        "ipfs_cid",
        "dashboard_url"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "market_id": {
          "type": "string",
          "minLength": 1
        },
        "market_question": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "raw_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "final_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ipfs_cid": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "dashboard_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "action_intent": {
      "oneOf": [
        { "$ref": "#/$defs/action_intent_prediction_market" },
        { "$ref": "#/$defs/action_intent_payment_batch" },
        { "$ref": "#/$defs/action_intent_defi_rebalance" },
        { "$ref": "#/$defs/action_intent_treasury_move" }
      ]
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sentinel_agent_id",
        "model_family",
        "model_name"
      ],
      "properties": {
        "sentinel_agent_id": {
          "type": "string",
          "minLength": 1
        },
        "model_family": {
          "enum": [
            "anthropic-claude",
            "openai-gpt"
          ]
        },
        "model_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verdict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict_score",
        "verdict_label",
        "raw_verdict_score",
        "capped_verdict_score"
      ],
      "properties": {
        "verdict_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "verdict_label": {
          "enum": [
            "REJECT",
            "WARN",
            "PASS",
            "ENDORSE"
          ]
        },
        "raw_verdict_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "The uncapped raw verdict score from the sentinel, before any policy clamping."
        },
        "capped_verdict_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "The verdict score after policy clamping (e.g., floor/cap by readiness or issue-ledger gates). The invariant capped_verdict_score <= raw_verdict_score MUST hold."
        },
        "response_uri": {
          "type": "string",
          "format": "uri",
          "description": "URI pointing to the ERC-8004 validation response offchain artifact (IPFS gateway URL or equivalent)."
        }
      }
    },
    "reasoning_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_count",
        "source_diversity",
        "thesis_steps",
        "evidence_reference_count",
        "evidence_coverage",
        "invalid_evidence_refs",
        "unsupported_thesis_steps",
        "risk_factor_count",
        "avg_evidence_confidence",
        "probability_delta",
        "has_falsification_language"
      ],
      "properties": {
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "source_diversity": {
          "type": "integer",
          "minimum": 0
        },
        "thesis_steps": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_reference_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "invalid_evidence_refs": {
          "type": "integer",
          "minimum": 0
        },
        "unsupported_thesis_steps": {
          "type": "integer",
          "minimum": 0
        },
        "risk_factor_count": {
          "type": "integer",
          "minimum": 0
        },
        "avg_evidence_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "probability_delta": {
          "type": "number",
          "minimum": 0
        },
        "has_falsification_language": {
          "type": "boolean"
        }
      }
    },
    "readiness": {
      "enum": [
        "usable",
        "needs_review",
        "not_ready"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "issue_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "issues"
      ],
      "properties": {
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_issues",
            "resolved_count",
            "unresolved_blocking_count",
            "unresolved_material_count",
            "clean_pass_allowed",
            "endorsement_allowed",
            "active_policy_constraints",
            "explanation"
          ],
          "properties": {
            "total_issues": {
              "type": "integer",
              "minimum": 0
            },
            "resolved_count": {
              "type": "integer",
              "minimum": 0
            },
            "unresolved_blocking_count": {
              "type": "integer",
              "minimum": 0
            },
            "unresolved_material_count": {
              "type": "integer",
              "minimum": 0
            },
            "clean_pass_allowed": {
              "type": "boolean"
            },
            "endorsement_allowed": {
              "type": "boolean"
            },
            "active_policy_constraints": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "explanation": {
              "type": "string"
            }
          }
        },
        "resolution_metadata": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "policy_version": {
              "type": "string",
              "minLength": 1
            },
            "resolution_strategy": {
              "type": "string",
              "minLength": 1
            },
            "applied_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "type",
              "severity",
              "blocking_pass",
              "resolution_status",
              "question",
              "required_resolution",
              "tool_status",
              "tool_provider",
              "tool_receipt",
              "resolved_by_evidence_tool"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "minLength": 1
              },
              "blocking_pass": {
                "type": "boolean"
              },
              "resolution_status": {
                "type": "string"
              },
              "question": {
                "type": "string"
              },
              "required_resolution": {
                "type": "string"
              },
              "claim_ref": {
                "type": "string"
              },
              "tool_status": {
                "enum": [
                  "resolved",
                  "fail_closed",
                  "not_recorded"
                ]
              },
              "tool_provider": {
                "type": "string"
              },
              "tool_receipt": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "source_content_hash",
                  "retrieved_at",
                  "provider"
                ],
                "properties": {
                  "source_url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "source_content_hash": {
                    "type": "string",
                    "pattern": "^0x[0-9a-fA-F]{64}$"
                  },
                  "retrieved_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "provider": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_title": {
                    "type": "string"
                  },
                  "source_excerpt": {
                    "type": "string"
                  }
                }
              },
              "resolved_by_evidence_tool": {
                "type": "boolean"
              },
              "latest_resolution": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "status",
                  "resolved_at"
                ],
                "properties": {
                  "status": {
                    "type": "string",
                    "minLength": 1
                  },
                  "resolved_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "evidence_receipt_ref": {
                    "type": "string",
                    "pattern": "^0x[0-9a-fA-F]{64}$",
                    "description": "Content hash reference into evidence_receipts[], linking to the evidence that backs this resolution."
                  }
                }
              }
            }
          }
        }
      }
    },
    "evidence_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_url",
          "source_content_hash",
          "retrieved_at",
          "provider",
          "adequacy_checks"
        ],
        "properties": {
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "source_content_hash": {
            "type": "string",
            "pattern": "^0x[0-9a-fA-F]{64}$"
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "provider": {
            "type": "string",
            "minLength": 1
          },
          "adequacy_checks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "capital_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "PENDING_VALIDATION",
            "BLOCK",
            "REVIEW",
            "ALLOW_PAPER",
            "ENDORSE"
          ]
        },
        "label": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        },
        "recommended_action": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "policy_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "validation_present",
            "trace_ready",
            "clean_pass_allowed",
            "endorsement_allowed"
          ],
          "properties": {
            "validation_present": {
              "type": "boolean"
            },
            "trace_ready": {
              "type": "boolean"
            },
            "clean_pass_allowed": {
              "type": "boolean"
            },
            "endorsement_allowed": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "payment_receipts": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/payment_receipt_x402" },
          { "$ref": "#/$defs/payment_receipt_mpp" },
          { "$ref": "#/$defs/payment_receipt_ap2" }
        ]
      }
    },
    "onchain_receipts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_arc_tx",
        "validation_arc_tx",
        "erc8004_request_hash"
      ],
      "properties": {
        "trace_arc_tx": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "validation_arc_tx": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "erc8004_request_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        }
      }
    },
    "content_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_json_hash",
        "verdict_json_hash",
        "report_json_hash"
      ],
      "properties": {
        "trace_json_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "verdict_json_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "report_json_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        }
      }
    }
  },
  "$defs": {
    "action_intent_prediction_market": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "market_id",
        "side"
      ],
      "properties": {
        "type": {
          "const": "prediction_market"
        },
        "market_id": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "enum": [
            "YES",
            "NO"
          ]
        },
        "size_usdc": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]{1,6})?$"
        },
        "builder_code": {
          "type": "string",
          "minLength": 1
        },
        "raw_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "final_probability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action_intent_payment_batch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "payment_batch"
        }
      },
      "description": "Reserved for future payment-batch action-intent semantics. Not implemented in v0."
    },
    "action_intent_defi_rebalance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "defi_rebalance"
        }
      },
      "description": "Reserved for future DeFi-rebalance action-intent semantics. Not implemented in v0."
    },
    "action_intent_treasury_move": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "treasury_move"
        }
      },
      "description": "Reserved for future treasury-move action-intent semantics. Not implemented in v0."
    },
    "payment_receipt_x402": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol",
        "tx_hash",
        "amount_usdc",
        "network"
      ],
      "properties": {
        "protocol": {
          "const": "x402"
        },
        "tx_hash": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        },
        "amount_usdc": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]{1,6})?$"
        },
        "network": {
          "type": "string",
          "minLength": 1
        },
        "chain_id": {
          "type": "integer",
          "minimum": 1
        },
        "payer": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "payee": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        }
      }
    },
    "payment_receipt_mpp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol"
      ],
      "properties": {
        "protocol": {
          "const": "mpp"
        },
        "receipt_header_hash": {
          "type": "string"
        }
      },
      "description": "Reserved for future MPP (Multiparty Payment Protocol) receipt semantics. Not implemented in v0."
    },
    "payment_receipt_ap2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol"
      ],
      "properties": {
        "protocol": {
          "const": "ap2"
        },
        "receipt_header_hash": {
          "type": "string"
        }
      },
      "description": "Reserved for future AP2 (Agent Payment Protocol v2) receipt semantics. Not implemented in v0."
    }
  }
}
